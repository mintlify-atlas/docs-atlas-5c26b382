  "keyFeatures": [
    "File-based routing system with nested layouts",
    "Server-side rendering (SSR) with client-side hydration",
    "Static site generation (prerendering)",
    "Form actions for progressive enhancement",
    "Load functions for data fetching",
    "Multiple deployment adapters (Node, Cloudflare, Netlify, Vercel, static)",
    "Built-in development server with HMR via Vite",
    "Type-safe routing and navigation",
    "Service worker support",
    "Image optimization"
  ],
  "publicApiSurface": [
    "error() - Throw HTTP errors",
    "redirect() - Perform redirects",
    "json() - Create JSON responses",
    "text() - Create text responses",
    "fail() - Handle form action failures",
    "invalid() - Throw validation errors",
    "isHttpError() - Check for HTTP errors",
    "isRedirect() - Check for redirects",
    "isActionFailure() - Check for action failures",
    "sequence() - Chain handle hooks",
    "$app/navigation - goto(), invalidate(), preloadData()",
    "$app/paths - base, assets, resolve()",
    "$app/stores - page, navigating, updated",
    "$app/environment - browser, dev, building, version",
    "$app/forms - enhance() for progressive form enhancement",
    "svelte-kit sync - CLI command to sync types",
    "adapter-auto - Auto-detect deployment platform",
    "adapter-node - Node.js deployment",
    "adapter-static - Static site generation",
    "adapter-cloudflare - Cloudflare deployment",
    "adapter-netlify - Netlify deployment",
    "adapter-vercel - Vercel deployment"
  ]
}
