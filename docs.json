{
  "$schema": "https://mintlify.com/docs.json",
  "name": "SvelteKit",
  "theme": "willow",
  "colors": {
    "primary": "#FF3E00",
    "light": "#FF3E00",
    "dark": "#FF3E00"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/sveltejs/kit"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/sveltejs/kit"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "introduction",
              "quickstart",
              "project-structure",
              "web-standards"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "core-concepts/routing",
              "core-concepts/load",
              "core-concepts/form-actions",
              "core-concepts/page-options",
              "core-concepts/state-management",
              "core-concepts/remote-functions"
            ]
          },
          {
            "group": "Build and Deploy",
            "pages": [
              "build-and-deploy/building",
              "build-and-deploy/adapters",
              "build-and-deploy/adapter-auto",
              "build-and-deploy/adapter-node",
              "build-and-deploy/adapter-static",
              "build-and-deploy/adapter-cloudflare",
              "build-and-deploy/adapter-netlify",
              "build-and-deploy/adapter-vercel"
            ]
          },
          {
            "group": "Advanced",
            "pages": [
              "advanced/hooks",
              "advanced/page-data",
              "advanced/service-workers",
              "advanced/errors",
              "advanced/link-options",
              "advanced/images"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Core Modules",
            "pages": [
              "api/sveltejs-kit",
              "api/sveltejs-kit-hooks",
              "api/sveltejs-kit-node",
              "api/sveltejs-kit-vite"
            ]
          },
          {
            "group": "$app Modules",
            "pages": [
              "api/app-environment",
              "api/app-forms",
              "api/app-navigation",
              "api/app-paths",
              "api/app-server",
              "api/app-state",
              "api/app-stores"
            ]
          },
          {
            "group": "$env Modules",
            "pages": [
              "api/env-dynamic-private",
              "api/env-dynamic-public",
              "api/env-static-private",
              "api/env-static-public"
            ]
          },
          {
            "group": "Configuration",
            "pages": [
              "api/configuration",
              "api/types"
            ]
          }
        ]
      }
    ]
  }
}
